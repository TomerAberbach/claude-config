{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "fileSuggestion": {
    "type": "command",
    "command": "/Users/tomer/.claude/file-suggestion.sh"
  },
  "respectGitignore": false,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(jj st *)",
      "Bash(jj status *)",
      "Bash(jj diff *)",
      "Bash(jj log *)",
      "Bash(jj show *)",
      "Bash(jj file show *)",
      "Bash(pnpm format *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm vitest * )",
      "Bash(pnpm test *)",
      "Bash(pnpm coverage *)",
      "Bash(pnpm bench *)",
      "Bash(pnpm build *)",
      "Bash(pnpm run format *)",
      "Bash(pnpm run lint *)",
      "Bash(pnpm run typecheck *)",
      "Bash(pnpm run vitest * )",
      "Bash(pnpm run test *)",
      "Bash(pnpm run coverage *)",
      "Bash(pnpm run build *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__ide__getDiagnostics"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude is waiting\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-create.sh"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-remove.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/tomer/.claude/statusline-command.sh"
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Brewing",
      "Burring",
      "Caffeinating",
      "Dialing",
      "Dosing",
      "Extracting",
      "Flushing",
      "Foaming",
      "Frothing",
      "Grinding",
      "Knocking",
      "Leveling",
      "Pouring",
      "Pulling",
      "Purging",
      "Roasting",
      "Sipping",
      "Steaming",
      "Steeping",
      "Stirring",
      "Swirling",
      "Tamping",
      "Texturing",
      "Weighing"
    ]
  },
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "skipWorkflowUsageWarning": true
}
