{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(jj diff *)",
      "Bash(jj log *)",
      "Bash(pnpm format *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm test *)",
      "Bash(pnpm build *)",
      "mcp__ide__getDiagnostics"
    ],
    "deny": [
      "Bash(git *)",
      "Bash(tsc *)"
    ]
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Brewing",
      "Burring",
      "Dialing",
      "Dosing",
      "Extracting",
      "Foaming",
      "Frothing",
      "Grinding",
      "Leveling",
      "Pouring",
      "Pulling",
      "Roasting",
      "Sipping",
      "Stirring",
      "Steaming",
      "Swirling",
      "Texturing",
      "Tamping",
      "Weighing"
    ]
  }
}
