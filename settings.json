{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(jj st *)",
      "Bash(jj status *)",
      "Bash(jj diff *)",
      "Bash(jj log *)",
      "Bash(jj show *)",
      "Bash(jj file show *)",
      "Bash(pnpm format *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm vitest * )",
      "Bash(pnpm test *)",
      "Bash(pnpm coverage *)",
      "Bash(pnpm bench *)",
      "Bash(pnpm build *)",
      "Bash(pnpm run format *)",
      "Bash(pnpm run lint *)",
      "Bash(pnpm run typecheck *)",
      "Bash(pnpm run vitest * )",
      "Bash(pnpm run test *)",
      "Bash(pnpm run coverage *)",
      "Bash(pnpm run build *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "mcp__ide__getDiagnostics"
    ],
    "deny": ["Bash(git *)", "Bash(tsc *)", "Bash(npm *)"]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/tomer/.claude/statusline-command.sh"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude is waiting\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "showClearContextOnPlanAccept": true,
  "enableAllProjectMcpServers": true,
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Brewing",
      "Burring",
      "Dialing",
      "Dosing",
      "Extracting",
      "Foaming",
      "Frothing",
      "Grinding",
      "Leveling",
      "Pouring",
      "Pulling",
      "Roasting",
      "Sipping",
      "Stirring",
      "Steaming",
      "Swirling",
      "Texturing",
      "Tamping",
      "Weighing"
    ]
  }
}
